# Server Configuration
PORT=3000
NODE_ENV=development
API_BASE_URL=http://localhost:3000

# Database Configuration
DUCKDB_PATH=./data/analytics.duckdb
SQLITE_PATH=./data/episodic_memory.db
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# AI Service Configuration
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Web Search Configuration
BING_SEARCH_API_KEY=your_bing_search_key_here
GOOGLE_SEARCH_API_KEY=your_google_search_key_here
GOOGLE_SEARCH_ENGINE_ID=your_search_engine_id_here

# Security Configuration
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=24h
BCRYPT_ROUNDS=12

# Data Configuration
CSV_ROSTER_PROCESSING_PATH=./data/roster_processing_details.csv
CSV_OPERATIONAL_METRICS_PATH=./data/aggregated_operational_metrics.csv

# Logging Configuration
LOG_LEVEL=info
LOG_FILE_PATH=./logs/rosteriq.log

# Performance Configuration
QUERY_TIMEOUT_MS=30000
CACHE_TTL_SECONDS=3600
MAX_CONCURRENT_QUERIES=10

# Memory Configuration
EPISODIC_MEMORY_MAX_ENTRIES=10000
PROCEDURAL_MEMORY_GIT_REPO=./data/procedures
SEMANTIC_MEMORY_EMBEDDINGS_PATH=./data/embeddings

# External Services
WEB_SEARCH_TIMEOUT_MS=5000
GEMINI_RATE_LIMIT_RPM=60
OPENAI_RATE_LIMIT_RPM=3000

# Security & Compliance
ENABLE_AUDIT_LOGGING=true
DATA_ENCRYPTION_KEY=your_encryption_key_here
HIPAA_COMPLIANCE_MODE=true